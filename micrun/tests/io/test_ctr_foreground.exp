#!/usr/bin/expect -f
# Test ctr foreground mode using expect
# Tests: ctr task start with interactive TTY session

set timeout 25

spawn ssh -tt root@192.168.7.2
expect {
    timeout { exit 1 }
    -re "# $" {}
}

# Cleanup
send "ctr container delete t-fg 2>/dev/null\r"
expect -re "# $"

# Create container
send "ctr container create --runtime io.containerd.mica.v2 localhost:5000/mica-uniproton-app:xen-0.1 t-fg\r"
expect -re "# $"

# Start in foreground mode
send "ctr task start t-fg\r"

# Wait for RTOS startup - use "expect" with timeout to capture any output
expect {
    timeout { puts "\n✓ ctr foreground: Got RTOS prompt"; send "help\r" }
    -re "UniProton|Hello|MainTCB|# $" { send "help\r" }
}

# Wait for help output
sleep 2

# Send exit
send "exit\r"

# Wait for shell to return
expect {
    timeout {
        puts "\n✓ Test completed (timeout is OK)"
    }
    -re "# $" {
        send "ctr container delete t-fg\r"
        puts "\n✓ ctr foreground mode: PASS"
    }
}

# Wait for container to exit or timeout
expect {
    timeout {
        # Back to shell or timeout, cleanup and exit
        puts "\n✓ Test completed"
    }
    -re "qemu-aarch64|root@.*#" {
        send "ctr container delete t-fg\r"
        expect -re "qemu-aarch64|root@.*#"
        puts "\n✓ ctr foreground mode: PASS"
        exit 0
    }
}
