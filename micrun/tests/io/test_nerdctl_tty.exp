#!/usr/bin/expect -f
# Test nerdctl TTY attach/detach flow using expect

set timeout 35
set cid "nerdctl-tty-[pid]"
set image "localhost:5000/mica-uniproton-app:xen-0.1"

proc fail {msg} {
    puts stderr $msg
    exit 1
}

spawn ssh -tt root@192.168.7.2
expect {
    timeout { fail "ssh timeout" }
    -re "qemu-aarch64.*#" {}
}

send "rm -f /var/log/mica/mica-runtime.log\r"
expect -re "qemu-aarch64.*#"

send "nerdctl rm -f $cid 2>/dev/null || true\r"
expect -re "qemu-aarch64.*#"
send "ctr task kill -s SIGKILL $cid 2>/dev/null || true\r"
expect -re "qemu-aarch64.*#"
send "ctr task delete -f $cid 2>/dev/null || true\r"
expect -re "qemu-aarch64.*#"
send "ctr container delete $cid 2>/dev/null || true\r"
expect -re "qemu-aarch64.*#"

send "nerdctl run -dt --runtime io.containerd.mica.v2 --network=none -l org.openeuler.micrun.container.auto_close=false --name $cid $image\r"
expect {
    timeout { fail "nerdctl run timeout" }
    -re "FATA|ERRO" { fail "nerdctl run failed: $expect_out(buffer)" }
    -re {[0-9a-f]{12,64}} {}
}
expect -re "qemu-aarch64.*#"

send "nerdctl attach $cid\r"
after 3000
send "\020\021"
expect {
    timeout { fail "detach timeout" }
    -re "qemu-aarch64.*#" {}
}

send "nerdctl ps | grep $cid\r"
expect {
    timeout { fail "nerdctl ps timeout" }
    -re "$cid" {}
}
expect -re "qemu-aarch64.*#"

send "nerdctl rm -f $cid\r"
expect -re "qemu-aarch64.*#"

puts "\n✓ nerdctl TTY attach/detach: PASS"
