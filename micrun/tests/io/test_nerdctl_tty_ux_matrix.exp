#!/usr/bin/expect -f
# Exercises user-facing nerdctl TTY behavior across foreground run, repeated
# attach/detach cycles, command bursts, partial input, Ctrl-C interrupt, and
# task cleanup.

set timeout 60
log_user 1

set host [expr {[info exists env(TEST_REMOTE_HOST)] ? $env(TEST_REMOTE_HOST) : "root@192.168.7.2"}]
set port [expr {[info exists env(TEST_REMOTE_PORT)] ? $env(TEST_REMOTE_PORT) : ""}]
set image [expr {[info exists env(TTY_TEST_IMAGE)] ? $env(TTY_TEST_IMAGE) : "localhost:5000/mica-uniproton-app:xen-0.1"}]
set cid [expr {[info exists env(TTY_TEST_CONTAINER_NAME)] ? $env(TTY_TEST_CONTAINER_NAME) : "micrun-tty-ux-[pid]"}]
set network_mode [expr {[info exists env(NERDCTL_NETWORK_MODE)] ? $env(NERDCTL_NETWORK_MODE) : "none"}]
set password [expr {[info exists env(TEST_REMOTE_PASSWORD)] ? $env(TEST_REMOTE_PASSWORD) : ""}]

set remote_prompt {MICRUN_REMOTE# $}
set shell_prompt {openEuler UniProton # ?}

proc fail {msg} {
    puts $msg
    exit 1
}

proc expect_remote_prompt {label} {
    global remote_prompt
    expect {
        timeout { fail "TTY_UX_MATRIX_FAIL ${label}: remote prompt timeout" }
        -re $remote_prompt {}
    }
}

proc expect_shell_prompt {label} {
    global shell_prompt
    expect {
        timeout { fail "TTY_UX_MATRIX_FAIL ${label}: UniProton prompt timeout" }
        -re $shell_prompt {}
    }
}

proc wait_or_nudge_shell_prompt {label} {
    global shell_prompt
    global timeout
    set saved_timeout $timeout
    set timeout 2
    expect {
        timeout {
            send "\r"
            set timeout $saved_timeout
            expect_shell_prompt $label
        }
        -re $shell_prompt {
            set timeout $saved_timeout
        }
    }
}

proc send_shell_line {line label} {
    send "$line\r"
    expect_shell_prompt $label
}

proc send_shell_line_expect {line marker label} {
    send "$line\r"
    expect {
        timeout { fail "TTY_UX_MATRIX_FAIL ${label}: missing marker ${marker}" }
        -re $marker {}
    }
    expect_shell_prompt $label
}

proc send_shell_burst_expect {payload markers label} {
    send $payload
    foreach marker $markers {
        expect {
            timeout { fail "TTY_UX_MATRIX_FAIL ${label}: missing marker ${marker}" }
            -re $marker {}
        }
    }
    expect_shell_prompt $label
}

proc detach_to_remote {label} {
    after 300
    send "\020\021"
    expect_remote_prompt $label
}

proc attach_to_shell {cid label} {
    send "nerdctl attach $cid\r"
    wait_or_nudge_shell_prompt $label
}

proc assert_container_up {cid label} {
    send "nerdctl ps | grep $cid\r"
    expect {
        timeout { fail "TTY_UX_MATRIX_FAIL ${label}: nerdctl ps timeout" }
        -re $cid {}
    }
    expect_remote_prompt $label
}

set ssh_base_opts [list -tt -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o GlobalKnownHostsFile=/dev/null -o LogLevel=ERROR]
if {$port ne ""} {
    lappend ssh_base_opts -p $port
}

if {$password ne ""} {
    spawn sshpass -p $password ssh {*}$ssh_base_opts -o PreferredAuthentications=keyboard-interactive,password -o PubkeyAuthentication=no -o KbdInteractiveAuthentication=yes $host
} else {
    spawn ssh {*}$ssh_base_opts $host
}

expect {
    timeout { fail "TTY_UX_MATRIX_FAIL ssh timeout" }
    -re {# $} {}
    -re {\$ $} {}
}

send "export PS1='MICRUN_REMOTE# '\r"
expect_remote_prompt "prompt normalization"

send "nerdctl rm -f $cid 2>/dev/null || true\r"
expect_remote_prompt "pre-clean nerdctl"
send "ctr task kill -s 9 $cid 2>/dev/null || true\r"
expect_remote_prompt "pre-clean task kill"
send "ctr task delete $cid 2>/dev/null || true\r"
expect_remote_prompt "pre-clean task delete"
send "ctr container delete $cid 2>/dev/null || true\r"
expect_remote_prompt "pre-clean container delete"
send "xl destroy $cid 2>/dev/null || true\r"
expect_remote_prompt "pre-clean xen"

send "nerdctl run -it --runtime io.containerd.mica.v2 --network=$network_mode -l org.openeuler.micrun.container.auto_close=false --name $cid $image\r"
wait_or_nudge_shell_prompt "foreground run"

send_shell_line "" "empty command"
send_shell_line_expect "help" {support shell commond} "foreground help"
send_shell_line "definitely-not-a-uniproton-command" "foreground invalid command"
send_shell_burst_expect "uname\rsysteminfo\r" [list {UniProton 24\.03-LTS} {Module[[:space:]]+Used[[:space:]]+Total}] "foreground pasted burst"
detach_to_remote "foreground detach"
assert_container_up $cid "after foreground detach"

attach_to_shell $cid "first attach"
send_shell_burst_expect "help\runame\r" [list {support shell commond} {UniProton 24\.03-LTS}] "first attach pasted burst"
detach_to_remote "first attach detach"
assert_container_up $cid "after first detach"

attach_to_shell $cid "second attach"
send_shell_burst_expect "taskInfo\rmemInfo\r" [list {SerialShellTask|TaskName|ID} {MEM_ARITH_FSC|percent|usedRate}] "second attach status commands"
detach_to_remote "second attach detach"
assert_container_up $cid "after second detach"

attach_to_shell $cid "partial input attach"
send "un"
detach_to_remote "partial input detach"
assert_container_up $cid "after partial detach"

attach_to_shell $cid "partial recovery attach"
send_shell_line "" "partial command completion"
send_shell_line_expect "uname" {UniProton 24\.03-LTS} "partial recovery command"

send "\003"
expect_remote_prompt "ctrl-c interrupt"

send "printf 'TASKS='; ctr task ls | awk '\$1==\"$cid\"{c++} END{print c+0}'\r"
expect {
    timeout { fail "TTY_UX_MATRIX_FAIL task cleanup check timeout" }
    -re {TASKS=0} {}
}
expect_remote_prompt "task cleanup"

send "printf 'XEN='; xl list | awk '\$1==\"$cid\"{c++} END{print c+0}'\r"
expect {
    timeout { fail "TTY_UX_MATRIX_FAIL xen cleanup check timeout" }
    -re {XEN=0} {}
}
expect_remote_prompt "xen cleanup"

send "nerdctl rm -f $cid 2>/dev/null || true\r"
expect_remote_prompt "final nerdctl cleanup"

puts "\nTTY_UX_MATRIX_PASS"
send "exit\r"
expect eof
