#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../common/env.sh"

case "${TEST_REMOTE_HOST}" in
    qemu-k3s|root@127.0.0.1|127.0.0.1)
        QEMU_KEEP_RUNNING="${QEMU_KEEP_RUNNING:-true}" \
        QEMU_GUEST_PASSWORD="${QEMU_GUEST_PASSWORD:-${TEST_REMOTE_PASSWORD:-}}" \
        "${SCRIPT_DIR}/test-qemu-smoke"
        ;;
esac

exec "${SCRIPT_DIR}/../io/run_qemu_regression.sh"
